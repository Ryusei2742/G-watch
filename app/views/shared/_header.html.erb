<header class="site-header">
  <nav class="site-header__nav">
    <div class="site-header__brand">
      <%= link_to "G-watch", root_path, class: "brand-link" %>
      <div class="site-header__links">
        <%= link_to "作品一覧", works_path, class: "nav-link" %>
        <% if logged_in? %>
          <%= link_to "レビュー一覧", reviews_path, class: "nav-link" %>
        <% end %>
      </div>
    </div>

    <div class="site-header__actions">
      <% if logged_in? %>
        <span class="user-chip"><%= current_user.name %></span>
        <%= button_to "ログアウト", logout_path,
              method: :delete,
              form: { class: "logout-form" },
              class: "nav-button" %>
      <% else %>
        <%= link_to "ログイン", login_path, class: "nav-link" %>
        <%= link_to "ユーザー登録", signup_path, class: "nav-link nav-link--primary" %>
      <% end %>
    </div>
  </nav>
</header>
