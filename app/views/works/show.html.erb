<div class="work-show">
  <% title = @work.title.to_s %>
  <% placeholder_label =
    if title.include?('機動戦士ガンダム')
      '初代'
    elsif title.include?('Zガンダム')
      'Z'
    elsif title.include?('SEED')
      'SEED'
    elsif title.include?('鉄血')
      '鉄血'
    elsif title.include?('水星')
      '水星'
    else
      title.each_char.first(2).join.presence || 'GW'
    end %>
  <% placeholder_tone =
    if title.include?('機動戦士ガンダム')
      'uc'
    elsif title.include?('Zガンダム')
      'zeta'
    elsif title.include?('SEED')
      'seed'
    elsif title.include?('鉄血')
      'ibo'
    elsif title.include?('水星')
      'witch'
    else
      'default'
    end %>

  <div class="work-hero">
    <div class="thumb">
      <% if @work.thumbnail.present? %>
        <%= image_tag("thumbnails/#{@work.thumbnail}", alt: "#{@work.title} サムネ") %>
      <% else %>
        <div class="thumb--placeholder thumb--placeholder-<%= placeholder_tone %>">
          <span class="thumb--placeholder-mark"><%= placeholder_label %></span>
        </div>
      <% end %>
    </div>

    <div class="meta">
      <p class="eyebrow"><%= @work.series.presence || "Series" %></p>
      <h1 class="title"><%= @work.title %></h1>

      <% if logged_in? && current_user.admin? %>
        <div class="admin-actions">
          <%= link_to '編集', edit_work_path(@work), class: 'btn btn-ghost btn-admin' %>
          <%= button_to '削除', work_path(@work),
                method: :delete,
                data: { confirm: 'この作品を削除しますか？' },
                class: 'btn btn-danger btn-admin' %>
        </div>
      <% end %>

      <div class="detail-metrics">
        <div class="metric-card">
          <span>シリーズ</span>
          <strong><%= @work.series.presence || '-' %></strong>
        </div>
        <div class="metric-card">
          <span>公開年</span>
          <strong><%= @work.year.presence || '-' %></strong>
        </div>
        <div class="metric-card">
          <span>おすすめ度</span>
          <strong>
            <% if @work.recommended.present? %>
              <%= number_with_precision(@work.recommended, precision: 1) %> / 5.0
            <% else %>
              未設定
            <% end %>
          </strong>
        </div>
        <div class="metric-card">
          <span>平均評価</span>
          <strong>
            <% if @avg_rating.present? %>
              <%= @avg_rating %> / 5.0
            <% else %>
              未評価
            <% end %>
          </strong>
          <% if @avg_rating.present? %>
            <small class="stars"><%= '★' * @avg_rating.to_i %><%= '☆' * (5 - @avg_rating.to_i) %></small>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <section class="description content-card">
    <div class="section-heading">
      <p class="eyebrow">Story</p>
      <h2>作品説明</h2>
    </div>
    <%= @work.description.present? ? simple_format(@work.description) : '説明はまだありません。' %>
  </section>

  <section class="reviews content-card">
    <div class="section-heading">
      <p class="eyebrow">Reviews</p>
      <h2>レビュー</h2>
    </div>

    <% if @reviews.any? %>
      <ul class="review-list">
        <% @reviews.each do |r| %>
          <li class="review-item">
            <div class="review-head">
              <div class="review-author">
                <span class="review-avatar"><%= (r.user&.name.presence || 'U').first %></span>
                <span><%= r.user&.name.presence || 'ユーザー' %></span>
              </div>
              <span class="rating">
                <% if r.rating.present? %>
                  <span class="review-stars"><%= '★' * r.rating %><%= '☆' * (5 - r.rating) %></span>
                  <span><%= r.rating %> / 5</span>
                <% else %>
                  評価なし
                <% end %>
              </span>
              <span class="status badge <%= r.status %>"><%= r.status.presence || '未設定' %></span>
              <span class="date"><%= l r.created_at, format: :short %> 投稿</span>
              <% if logged_in? && r.user == current_user %>
                <%= button_to '削除', review_path(r),
                      method: :delete,
                      form: { class: 'review-delete-form' },
                      data: { confirm: 'このレビューを削除しますか？' },
                      class: 'btn btn-danger btn-sm' %>
              <% end %>
            </div>
            <div class="review-body">
              <%= r.comment.present? ? simple_format(r.comment) : 'コメントなし' %>
            </div>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="empty-message">まだレビューはありません。</p>
    <% end %>
  </section>

  <section class="review-form content-card">
    <div class="section-heading">
      <p class="eyebrow">Your Review</p>
      <h3>レビューを投稿する</h3>
    </div>

    <% if logged_in? %>
      <%= form_with model: [@work, @review], local: true do |f| %>
        <div class="field">
          <%= f.label :status, 'ステータス' %>
          <%= f.select :status, [['視聴予定', 'planned'], ['視聴済み', 'watched']], include_blank: '選択してください' %>
        </div>

        <div class="field">
          <%= f.label :rating, '評価(1〜5)' %>
          <%= f.number_field :rating, min: 1, max: 5, step: 1 %>
        </div>

        <div class="field">
          <%= f.label :comment, 'コメント' %>
          <%= f.text_area :comment, rows: 4 %>
        </div>

        <div class="actions">
          <%= f.submit '投稿する', class: 'btn btn-primary' %>
        </div>
      <% end %>
    <% else %>
      <div class="login-prompt">
        <p>ログインすると、この作品への視聴ステータス・評価・コメントを投稿できます。</p>
        <%= link_to 'ログインへ', login_path, class: 'btn btn-primary' %>
      </div>
    <% end %>
  </section>
</div>
