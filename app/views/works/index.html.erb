<div class="works-index">
  <div class="page-heading">
    <div>
      <p class="eyebrow">Works</p>
      <h1>作品一覧</h1>
      <p>登録されているガンダム作品を確認できます。</p>
    </div>

    <% if logged_in? && current_user.admin? %>
      <%= link_to '新しい作品を登録する', new_work_path, class: 'btn btn-primary' %>
    <% end %>
  </div>

  <div class="works-toolbar">
    <p><%= @works.size %>作品を表示中</p>
    <div class="sort-tabs" aria-label="作品の並び順">
      <%= link_to '新しい順', works_path(sort: 'newest'), class: ['sort-tab', ('active' if @sort_order == 'newest')].compact.join(' ') %>
      <%= link_to '古い順', works_path(sort: 'oldest'), class: ['sort-tab', ('active' if @sort_order == 'oldest')].compact.join(' ') %>
    </div>
  </div>

  <div class="works-grid">
    <% if @works.any? %>
      <% @works.each do |work| %>
        <% title = work.title.to_s %>
        <% placeholder_label =
          if title.include?('機動戦士ガンダム')
            '初代'
          elsif title.include?('Zガンダム')
            'Z'
          elsif title.include?('SEED')
            'SEED'
          elsif title.include?('鉄血')
            '鉄血'
          elsif title.include?('水星')
            '水星'
          elsif title.include?('逆襲のシャア')
            'CCA'
          elsif title.include?('ガンダムUC')
            'UC'
          elsif title.include?('ガンダム00')
            '00'
          elsif title.include?('ガンダムW')
            'W'
          elsif title.include?('Gガンダム')
            'G'
          else
            title.each_char.first(2).join.presence || 'GW'
          end %>
        <% placeholder_tone =
          if title.include?('機動戦士ガンダム')
            'uc'
          elsif title.include?('Zガンダム')
            'zeta'
          elsif title.include?('SEED')
            'seed'
          elsif title.include?('鉄血')
            'ibo'
          elsif title.include?('水星')
            'witch'
          elsif title.include?('逆襲のシャア')
            'cca'
          elsif title.include?('ガンダムUC')
            'unicorn'
          elsif title.include?('ガンダム00')
            'double-o'
          elsif title.include?('ガンダムW')
            'wing'
          elsif title.include?('Gガンダム')
            'fighter'
          else
            'default'
          end %>
        <% average_rating = work.reviews.average(:rating)&.round(1) %>
        <% review_count = work.reviews.count %>
        <% average_stars = average_rating.present? ? average_rating.to_f.round.clamp(0, 5) : nil %>
        <% series_class =
          if work.series.to_s.include?('宇宙世紀')
            'series-tag--uc'
          elsif work.series.to_s.include?('オルタナティブ')
            'series-tag--alternative'
          else
            'series-tag--default'
          end %>
        <%= link_to work_path(work), class: "work-card", aria: { label: "#{work.title.presence || '作品'}の詳細を見る" } do %>
          <div class="<%= ["work-card__image", ("work-card__image--placeholder work-card__image--#{placeholder_tone}" unless work.thumbnail.present?)].compact.join(" ") %>">
            <% if work.thumbnail.present? %>
              <%= image_tag("thumbnails/#{work.thumbnail}", alt: "#{work.title}のサムネイル") %>
            <% else %>
              <span class="work-card__placeholder">
                <span class="work-card__placeholder-mark"><%= placeholder_label %></span>
              </span>
            <% end %>
          </div>

          <div class="work-card__body">
            <div class="work-card__topline">
              <span class="work-card__series series-tag <%= series_class %>"><%= work.series.presence || "シリーズ未設定" %></span>
              <span class="work-card__year"><%= work.year.presence || "-" %></span>
            </div>

            <h2><%= work.title.presence || "タイトル未設定" %></h2>

            <div class="work-card__footer">
              <span class="score-pill">
                <span class="score-label">平均評価</span>
                <% if average_rating.present? %>
                  <span class="score-value">
                    <span class="score-stars"><%= '★' * average_stars %><%= '☆' * (5 - average_stars) %></span>
                    <strong><%= number_with_precision(average_rating, precision: 1) %></strong>
                  </span>
                <% else %>
                  <strong>
                    未評価
                  </strong>
                <% end %>
                <span class="review-count"><%= review_count %>件</span>
              </span>
              <span class="work-card__more">詳細へ</span>
            </div>
          </div>
        <% end %>
      <% end %>
    <% else %>
      <p class="empty-message">まだ作品が登録されていません。</p>
    <% end %>
  </div>
</div>
