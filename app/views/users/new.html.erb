<div class="auth-page">
  <section class="auth-card auth-card--signup">
    <div class="auth-card__header">
      <p class="eyebrow">Sign Up</p>
      <h1>ユーザー登録</h1>
      <p>レビュー投稿と記録機能をはじめましょう。</p>
    </div>

    <%= form_with model: @user, url: signup_path, local: true, class: 'auth-form' do |f| %>
      <div class="auth-field">
        <%= f.label :name, '名前' %>
        <%= f.text_field :name, autocomplete: 'name' %>
      </div>

      <div class="auth-field">
        <%= f.label :email, 'メールアドレス' %>
        <%= f.email_field :email, autocomplete: 'email' %>
      </div>

      <div class="auth-field">
        <%= f.label :password, 'パスワード' %>
        <%= f.password_field :password, autocomplete: 'new-password' %>
      </div>

      <div class="auth-field">
        <%= f.label :password_confirmation, 'パスワード（確認）' %>
        <%= f.password_field :password_confirmation, autocomplete: 'new-password' %>
      </div>

      <div class="auth-actions">
        <%= f.submit '登録する', class: 'btn btn-primary auth-submit' %>
      </div>
    <% end %>

    <p class="auth-switch">
      すでにアカウントをお持ちの方は <%= link_to 'ログイン', login_path %>
    </p>
  </section>
</div>
