<div class="auth-page">
  <section class="auth-card">
    <div class="auth-card__header">
      <p class="eyebrow">Login</p>
      <h1>ログイン</h1>
      <p>レビュー投稿や記録機能を利用できます。</p>
    </div>

    <%= form_with url: login_path, local: true, class: 'auth-form' do |f| %>
      <div class="auth-field">
        <%= label_tag :email, 'メールアドレス' %>
        <%= email_field_tag :email, nil, placeholder: 'user@example.com', autocomplete: 'email' %>
      </div>

      <div class="auth-field">
        <%= label_tag :password, 'パスワード' %>
        <%= password_field_tag :password, nil, placeholder: 'password', autocomplete: 'current-password' %>
      </div>

      <div class="auth-actions">
        <%= submit_tag 'ログイン', class: 'btn btn-primary auth-submit' %>
      </div>
    <% end %>

    <div class="auth-demo">
      <p>テスト用アカウント</p>
      <dl>
        <div>
          <dt>一般ユーザー</dt>
          <dd>user@example.com / password</dd>
        </div>
        <div>
          <dt>管理者</dt>
          <dd>admin@example.com / password</dd>
        </div>
      </dl>
    </div>
  </section>
</div>
